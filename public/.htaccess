<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /bytemarket/public/
    
    # Prevent rewrite loop - don't rewrite if already going through index.php
    RewriteCond %{REQUEST_URI} !^/bytemarket/public/index\.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    ErrorDocument 404 index.php
</IfModule>
